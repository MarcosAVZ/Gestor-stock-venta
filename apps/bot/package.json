{
  "name": "@compras-whatsapp/bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "WhatsApp bot + Express API. Receives capturas, runs OCR, drives the conversation state machine, persists to PostgreSQL.",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "lint": "eslint . --max-warnings=0",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@compras-whatsapp/shared": "workspace:*",
    "@compras-whatsapp/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
