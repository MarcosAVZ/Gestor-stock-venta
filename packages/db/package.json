{
  "name": "@compras-whatsapp/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prisma schema, generated client, and DB-level helpers. Provides @compras-whatsapp/db to apps/bot.",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\" \"tests/**/*.ts\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "prisma:format": "prisma format --schema=prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@compras-whatsapp/shared": "workspace:*",
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
