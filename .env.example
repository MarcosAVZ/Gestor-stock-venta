# =============================================================================
# Sistema de Gestión de Compras WhatsApp — Variables de entorno
# =============================================================================
# Copiá este archivo a `.env` y completá los valores reales:
#   cp .env.example .env
# IMPORTANTE: `.env` está en .gitignore — NUNCA lo commitees.
# =============================================================================

# --- Entorno ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# --- PostgreSQL (docker compose) -------------------------------------------
# Usuario y DB por defecto. Cambialos solo si tenés una razón concreta.
POSTGRES_USER=sgcw
POSTGRES_DB=sgcw
# Puerto en el host (no en el contenedor). 5432 es el default de Postgres.
POSTGRES_PORT=5432

# Contraseña del usuario Postgres. REQUERIDO.
# Generala con: openssl rand -hex 24
DB_PASSWORD=changeme_replace_me_with_a_long_random_string

# Cadena de conexión que usará la app.
# - Dentro de docker compose: el host es `postgres` (nombre del servicio).
# - Desde tu máquina (nativo, sin docker): usá `localhost`.
DATABASE_URL=postgresql://sgcw:changeme_replace_me_with_a_long_random_string@localhost:5432/sgcw

# --- Autorización (OWASP A01) ----------------------------------------------
# Lista de números de WhatsApp permitidos, separados por coma SIN espacios.
# Formato E.164 internacional: +<código_país><número>. Ejemplo Argentina: +5491112345678
# Estos son los ÚNICOS números que el bot va a responder.
OWNER_PHONE_NUMBERS=+5491112345678,+5491198765432

# --- OCR (PR4, placeholders para PR1) -------------------------------------
# Ruta al directorio con modelos de Tesseract. En Docker apuntará a
# /usr/share/tesseract-ocr/4.00/tessdata/ (incluye spa.traineddata en PR3).
# En nativo podés dejar el default del sistema.
TESSDATA_PATH=/usr/share/tesseract-ocr/4.00/tessdata/
# Concurrencia del pool de workers OCR (1-4 razonable).
OCR_CONCURRENCY=2
# Timeout en milisegundos por imagen.
OCR_TIMEOUT_MS=30000
